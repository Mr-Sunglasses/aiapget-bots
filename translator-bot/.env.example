BOT_TOKEN=your_telegram_bot_token

# LLM Provider: "openai" (any OpenAI-compatible API) or "anthropic"
LLM_PROVIDER=openai
LLM_BASE_URL=http://192.168.1.83:3080/qwen/compatible-mode/v1
LLM_API_KEY=not-needed
LLM_MODEL=qwen-plus

# Only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

TRANSLATION_CACHE_PATH=.translation_cache.json
USAGE_LOG_PATH=.usage_log.json
MAX_FILE_SIZE_MB=20
